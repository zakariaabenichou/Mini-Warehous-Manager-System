@model Mini_Warehous_Manager_System.ViewModels.ProductDetailsViewModel

@{
    ViewData["Title"] = "Warenbewegungen Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📜 Bewegungshistorie für @Model.Name</h2>
        <a asp-action="Index" class="btn btn-secondary">Zurück zur Übersicht</a>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4>Stammdaten</h4>
                    <hr />
                    <p class="mb-1"><strong>Artikel:</strong> @Model.Name</p>
                    <p class="mb-1"><strong>SKU:</strong> @Model.SKU</p>
                    <p class="mb-0"><strong>Lagerbestand:</strong> <span class="badge bg-success fs-6">@Model.CurrentStock Stk.</span></p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4>Protokoll</h4>
                    <hr />
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Datum / Uhrzeit</th>
                                <th>Menge</th>
                                <th>Grund / Referenz</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Movements.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted">Bisher noch keine Bewegungen für dieses Produkt protokolliert.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var movement in Model.Movements)
                                {
                                    <tr>
                                        <td>@movement.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                                        <td>
                                            <span class="badge @(movement.Quantity > 0 ? "bg-success" : "bg-danger")">
                                                @(movement.Quantity > 0 ? "+" : "")@movement.Quantity
                                            </span>
                                        </td>
                                        <td>@movement.Reason</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>