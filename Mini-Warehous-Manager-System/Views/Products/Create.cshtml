@{
    ViewData["Title"] = "Produkt anlegen";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2>🆕 Neues Produkt registrieren</h2>
    <p class="text-muted">Trage hier die Stammdaten des neuen Artikels ein.</p>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label">SKU / Artikelnummer</label>
                    <input name="sku" class="form-control" placeholder="z.B. APP-IPHONE-15" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Produkt-Name</label>
                    <input name="name" class="form-control" placeholder="z.B. Apple iPhone 15 Pro" required />
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Zurück</a>
                    <button type="submit" class="btn btn-primary">Produkt speichern</button>
                </div>
            </form>
        </div>
    </div>
</div>